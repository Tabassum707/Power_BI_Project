# Use Ubuntu 24.04 as base
FROM ubuntu:20.04


#FROM node:12.22.9-bullseye
# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install curl, ca-certificates, and xz-utils (needed for .tar.xz)
RUN apt-get update && apt-get install -y \
    curl \
    nano \
    ca-certificates \
    xz-utils \
    build-essential \
    python2 \
    && rm -rf /var/lib/apt/lists/*

# Download and install Node.js 12.22.9
RUN curl -fsSL https://nodejs.org/dist/v8.5.0/node-v8.5.0-linux-x64.tar.xz -o /tmp/node.tar.xz \
    && tar -xf /tmp/node.tar.xz -C /usr/local --strip-components=1 \
    && rm /tmp/node.tar.xz

# Verify installation
RUN node --version && npm --version

# Set working directory
WORKDIR /workdir

# Default shell
CMD ["/bin/bash"]