# Dockerfile
FROM ubuntu:24.04

# Install Node.js 22.4.1
RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL https://nodejs.org/dist/v22.4.1/node-v22.4.1-linux-x64.tar.gz -o node.tar.gz \
    && tar -xzf node.tar.gz -C /usr/local --strip-components=1 \
    && rm node.tar.gz \
    && apt-get purge -y --auto-remove curl \
    && rm -rf /var/lib/apt/lists/*

# Verify installation
RUN node --version

# Create a working directory
WORKDIR /workspace

# Default command
CMD ["/bin/bash"]